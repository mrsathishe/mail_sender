# App
APP_URL=http://localhost:3000

# JWT session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-openssl-rand-base64-32

# MongoDB (password must be URL-encoded in the URI: @ -> %40)
MONGO_URI=mongodb://user:pass@host:27017/mail_sender?authSource=mail_sender

# Sender Gmail (ours) — use a Gmail App Password, not the account password
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional; defaults to SMTP_USER
SMTP_FROM=youraccount@gmail.com
